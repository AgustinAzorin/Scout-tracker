# Supabase
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Auth
JWT_SECRET=your-super-secret-key-minimum-32-characters
JWT_EXPIRY=1h
REFRESH_TOKEN_EXPIRY_DAYS=7

# Google OAuth
GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=xxx
GOOGLE_REDIRECT_URI=https://your-backend.onrender.com/api/auth/oauth/google/callback

# Google Sheets service account
GOOGLE_SHEETS_SERVICE_ACCOUNT_JSON={"type":"service_account"}

# Web Push (VAPID)
VAPID_PUBLIC_KEY=xxx
VAPID_PRIVATE_KEY=xxx
VAPID_SUBJECT=mailto:admin@scouttracker.com

# Email
RESEND_API_KEY=re_xxx
FROM_EMAIL=noreply@scouttracker.com

# CORS
ALLOWED_ORIGINS=https://scout-web.onrender.com,exp://your-expo-url

# URLs
NEXT_PUBLIC_APP_URL=https://your-backend.onrender.com
FRONTEND_WEB_URL=https://scout-web.onrender.com